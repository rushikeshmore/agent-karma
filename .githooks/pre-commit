#!/bin/sh
# Identity guard — keep work identity out of personal repo.
# Apr 19 incident: work email leaked into commits, remote was force-fixed.
# This hook prevents recurrence.

EXPECTED_EMAIL="rushikeshmore271@gmail.com"
FORBIDDEN_PATTERN='coalitiontechnologies\|rushikeshmore21'

actual_email=$(git config user.email)
if [ "$actual_email" != "$EXPECTED_EMAIL" ]; then
  echo "pre-commit: blocked — git user.email is '$actual_email', expected '$EXPECTED_EMAIL'"
  echo "fix: git config user.email '$EXPECTED_EMAIL'"
  exit 1
fi

if git diff --cached -U0 -- ':!.githooks/' | grep -qi "$FORBIDDEN_PATTERN"; then
  echo "pre-commit: blocked — staged diff contains a forbidden identity pattern"
  echo "matches:"
  git diff --cached -U0 -- ':!.githooks/' | grep -in "$FORBIDDEN_PATTERN" | head -5
  exit 1
fi

exit 0
